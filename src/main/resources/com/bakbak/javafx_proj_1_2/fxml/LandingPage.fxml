<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="700.0" prefWidth="900.0" styleClass="landing-background" stylesheets="@LandingPage.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1">

   <center>
      <VBox alignment="CENTER" prefHeight="450.0" prefWidth="900.0" spacing="40" styleClass="landing-container">

         <!-- Logo and Title Section -->
         <VBox alignment="CENTER" prefHeight="350.0" prefWidth="700.0" spacing="25">

            <!-- Bird Icon with Animation -->
            <ImageView fx:id="birdIcon" fitHeight="140.0" fitWidth="140.0" pickOnBounds="true" preserveRatio="true" styleClass="bird-icon">
               <image>
                  <Image url="@icons/birdIcon.png" />
               </image>
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </ImageView>

            <!-- App Title Container -->
            <VBox alignment="CENTER" spacing="12" styleClass="title-section" maxWidth="600.0">
               <Text styleClass="app-title" text="BakBak">
                  <font>
                     <Font name="Inter Bold" size="56.0" />
                  </font>
               </Text>
               <Text styleClass="app-subtitle" text="Modern LAN Messaging Experience">
                  <font>
                     <Font name="Inter" size="20.0" />
                  </font>
               </Text>

               <!-- Decorative Dots -->
               <HBox alignment="CENTER" spacing="8" styleClass="decorative-section">
                  <VBox.margin>
                     <Insets top="15.0" />
                  </VBox.margin>
                  <Circle fill="#4c566a" radius="3.0" styleClass="decorative-dot" />
                  <Circle fill="#4c566a" radius="3.0" styleClass="decorative-dot" />
                  <Circle fill="#4c566a" radius="3.0" styleClass="decorative-dot" />
               </HBox>
            </VBox>

         </VBox>

         <!-- Spacer -->
         <Region prefHeight="20.0" />

      </VBox>
   </center>

   <bottom>
      <VBox styleClass="credits-container" prefHeight="200.0" prefWidth="900.0">
         <HBox alignment="CENTER" spacing="40" prefHeight="150.0" prefWidth="900.0">

            <!-- Developers Section -->
            <VBox alignment="CENTER" prefHeight="130.0" prefWidth="350.0" styleClass="credits-box" spacing="8">
               <Label styleClass="credits-title" text="DEVELOPED BY">
                  <font>
                     <Font name="Inter Bold" size="16.0" />
                  </font>
               </Label>

               <VBox alignment="CENTER" spacing="6">
                  <Label styleClass="credits-name" text="Abrar Ryan">
                     <font>
                        <Font name="Inter Medium" size="14.0" />
                     </font>
                  </Label>
                  <Label styleClass="credits-name" text="ID: 2305149" opacity="0.8">
                     <font>
                        <Font name="Inter" size="12.0" />
                     </font>
                  </Label>

                  <Region prefHeight="8.0" />

                  <Label styleClass="credits-name" text="Farhan Anjum">
                     <font>
                        <Font name="Inter Medium" size="14.0" />
                     </font>
                  </Label>
                  <Label styleClass="credits-name" text="ID: 2305142" opacity="0.8">
                     <font>
                        <Font name="Inter" size="12.0" />
                     </font>
                  </Label>
               </VBox>
            </VBox>

            <!-- Supervisor Section -->
            <VBox alignment="CENTER" prefHeight="130.0" prefWidth="350.0" styleClass="credits-box" spacing="8">
               <Label styleClass="credits-title" text="SUPERVISED BY">
                  <font>
                     <Font name="Inter Bold" size="16.0" />
                  </font>
               </Label>

               <VBox alignment="CENTER" spacing="6">
                  <Label styleClass="credits-name" text="Md Ishrak Ahsan Sir">
                     <font>
                        <Font name="Inter Medium" size="14.0" />
                     </font>
                  </Label>
                  <Label styleClass="credits-name" text="Project Supervisor" opacity="0.8">
                     <font>
                        <Font name="Inter" size="12.0" />
                     </font>
                  </Label>
               </VBox>
            </VBox>

         </HBox>

         <!-- Bottom Padding -->
         <Region prefHeight="25.0" />
      </VBox>
   </bottom>

</BorderPane>