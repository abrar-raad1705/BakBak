<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bakbak.javafx_proj_1_2.ChatController">


   <center>
      <SplitPane dividerPositions="0.25" BorderPane.alignment="CENTER">
        <items>
            <VBox>
                <children>
                    <Label text="Contacts">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                        <padding>
                            <Insets bottom="5.0" left="10.0" top="5.0" />
                        </padding>
                    </Label>
                    <ListView fx:id="contactsListView" VBox.vgrow="ALWAYS" />
                </children>
            </VBox>

            <BorderPane>
                <top>
                    <!-- Header Bar -->
                    <HBox alignment="CENTER_LEFT" prefHeight="70.0" style="-fx-background-color: #2C3E50; -fx-padding: 10;" spacing="15.0">
                       <children>
                          <!-- User Avatar -->
                          <StackPane prefHeight="50.0" prefWidth="50.0" style="-fx-background-color: #3498DB; -fx-background-radius: 25;">
                             <children>
                                <Label fx:id="userAvatarLabel" text="BC" textFill="WHITE">
                                   <font>
                                      <Font name="System Bold" size="18.0" />
                                   </font>
                                </Label>
                             </children>
                          </StackPane>

                          <!-- User Info -->
                          <VBox spacing="2.0">
                             <children>
                                <Label fx:id="chatPartnerNameLabel" text="BakBak Chat" textFill="WHITE">
                                   <font>
                                      <Font name="System Bold" size="16.0" />
                                   </font>
                                </Label>
                                <Label fx:id="statusLabel" text="Connected" textFill="#95A5A6">
                                   <font>
                                      <Font size="12.0" />
                                   </font>
                                </Label>
                             </children>
                          </VBox>

                          <!-- Spacer -->
                          <Region HBox.hgrow="ALWAYS" />

                          <!-- Action Buttons -->
                          <HBox spacing="10.0">
                             <children>
                                <Button fx:id="callButton" mnemonicParsing="false" onAction="#onCallAction" prefHeight="35.0" prefWidth="35.0" style="-fx-background-color: #27AE60; -fx-background-radius: 17.5; -fx-text-fill: white;" text="📞" />
                                <Button fx:id="videoButton" mnemonicParsing="false" onAction="#onVideoAction" prefHeight="35.0" prefWidth="35.0" style="-fx-background-color: #E74C3C; -fx-background-radius: 17.5; -fx-text-fill: white;" text="📹" />
                                <Button fx:id="moreButton" mnemonicParsing="false" onAction="#onMoreAction" prefHeight="35.0" prefWidth="35.0" style="-fx-background-color: #95A5A6; -fx-background-radius: 17.5; -fx-text-fill: white;" text="⋯" />
                             </children>
                          </HBox>
                       </children>
                    </HBox>
                </top>
                <center>
                    <!-- Chat Messages Area -->
                    <TextArea fx:id="chatArea" editable="false" wrapText="true" style="-fx-background-color: #ECF0F1; -fx-control-inner-background: #ECF0F1; -fx-text-fill: #2C3E50; -fx-font-size: 14px;" BorderPane.alignment="CENTER" />
                </center>
                <bottom>
                    <!-- Message Input Area -->
                    <VBox style="-fx-background-color: #FFFFFF; -fx-border-color: #BDC3C7; -fx-border-width: 1 0 0 0;">
                       <children>
                          <!-- Typing Indicator -->
                          <HBox fx:id="typingIndicator" alignment="CENTER_LEFT" managed="false" prefHeight="30.0" style="-fx-padding: 5 15;" visible="false">
                             <children>
                                <Label text="Someone is typing..." textFill="#7F8C8D">
                                   <font>
                                      <Font size="12.0" />
                                   </font>
                                </Label>
                                <Label fx:id="typingDots" text="..." textFill="#7F8C8D">
                                   <font>
                                      <Font name="System Bold" size="12.0" />
                                   </font>
                                </Label>
                             </children>
                          </HBox>

                          <!-- Input Controls -->
                          <HBox alignment="CENTER" spacing="10.0" style="-fx-padding: 15;">
                             <children>
                                <!-- Attachment Button -->
                                <Button fx:id="attachButton" mnemonicParsing="false" onAction="#onAttachAction" prefHeight="40.0" prefWidth="40.0" style="-fx-background-color: #95A5A6; -fx-background-radius: 20; -fx-text-fill: white;" text="📎" />

                                <!-- Message Input -->
                                <TextField fx:id="messageField" onAction="#onSendMessage" promptText="Type a message..." style="-fx-background-color: #F8F9FA; -fx-border-color: #E9ECEF; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 10;" HBox.hgrow="ALWAYS">
                                   <font>
                                      <Font size="14.0" />
                                   </font>
                                </TextField>

                                <!-- Emoji Button -->
                                <Button fx:id="emojiButton" mnemonicParsing="false" onAction="#onEmojiAction" prefHeight="40.0" prefWidth="40.0" style="-fx-background-color: #F39C12; -fx-background-radius: 20; -fx-text-fill: white;" text="😊" />

                                <!-- Send Button -->
                                <Button fx:id="sendButton" onAction="#onSendMessage" prefHeight="40.0" prefWidth="40.0" style="-fx-background-color: #3498DB; -fx-background-radius: 20; -fx-text-fill: white;" text="➤" />
                             </children>
                          </HBox>
                       </children>
                    </VBox>
                </bottom>
            </BorderPane>
        </items>
      </SplitPane>
   </center>


</BorderPane>