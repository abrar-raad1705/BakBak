<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bakbak.javafx_proj_1_2.LoginController">
   <children>
      <!-- Header -->
      <VBox alignment="CENTER" styleClass="login-header">
         <children>
            <Label fx:id="titleLabel" styleClass="app-title" text="Telegram" />
            <Label styleClass="app-subtitle" text="Please sign in to your account" />
         </children>
         <padding>
            <Insets bottom="30.0" left="20.0" right="20.0" top="40.0" />
         </padding>
      </VBox>
      
      <!-- Login Form -->
      <VBox fx:id="loginContainer" alignment="CENTER" spacing="20.0" styleClass="login-form">
         <children>
            <TextField fx:id="usernameField" maxWidth="300.0" promptText="Username" styleClass="login-field" />
            <PasswordField fx:id="passwordField" maxWidth="300.0" promptText="Password" styleClass="login-field" />
            
            <!-- Status Label -->
            <Label fx:id="statusLabel" styleClass="status-label" visible="false" />
            
            <!-- Loading Indicator -->
            <ProgressIndicator fx:id="loadingIndicator" maxHeight="30.0" maxWidth="30.0" visible="false" />
            
            <!-- Buttons -->
            <VBox alignment="CENTER" spacing="10.0">
               <children>
                  <Button fx:id="loginButton" maxWidth="300.0" minWidth="300.0" styleClass="primary-button" text="Sign In" />
                  <Button fx:id="registerButton" maxWidth="300.0" minWidth="300.0" styleClass="secondary-button" text="Create Account" />
               </children>
            </VBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
      
      <!-- Footer -->
      <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
         <children>
            <Label styleClass="footer-text" text="Connect with friends and family" />
         </children>
         <padding>
            <Insets bottom="20.0" />
         </padding>
      </VBox>
   </children>
</VBox> 